{
  "manifest_version": 3,
  "name": "Canvas Meet Sync",
  "version": "1.1.0",
  "description": "Captures Google Meet captions and syncs them to your AI Canvas room",
  "permissions": ["activeTab", "storage"],
  "host_permissions": [
    "https://meet.google.com/*",
    "http://localhost/*",
    "http://192.168.*.*/*",
    "<all_urls>"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["https://meet.google.com/*"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ],
  "action": {
    "default_popup": "popup.html"
  }
}
